{{ if ne .chezmoi.distro.like "suse opensuse" }}{{ else -}}
#!/bin/sh
CYAN='\033[0;36m'
LCYAN='\033[1;36m'
RESET='\033[0m'

# --- Core (always installed) ---
printf "${LCYAN}###${RESET} Refreshing zypper repositories\n"
sudo zypper refresh

printf "${LCYAN}###${RESET} Installing core packages\n"
sudo zypper -n install {{ .packages.core.opensuse.zypper | join " " }}

# --- mise (curl install) ---
if ! command -v mise > /dev/null 2>&1 && [ ! -x "$HOME/.local/bin/mise" ]; then
    printf "${LCYAN}###${RESET} Installing mise\n"
    curl https://mise.run | sh
fi

# --- oh-my-posh (curl install) ---
if ! command -v oh-my-posh > /dev/null 2>&1; then
    curl -s https://ohmyposh.dev/install.sh | bash -s
fi

# --- Selected groups ---
{{- range $group := .package_groups }}
{{-   $gdata := index $.packages $group }}
{{-   if $gdata }}
printf "${LCYAN}###${RESET} Installing group: {{ $group }} — {{ index $gdata "description" }}\n"
{{-     $opensuse := index $gdata "opensuse" | default dict }}
{{-     with (index $opensuse "zypper" | default list) }}
{{-       $pkgs := . }}
{{-       range (index $ "disabled_packages" | default list) }}{{- $pkgs = without $pkgs . }}{{- end }}
{{-       if $pkgs }}
sudo zypper -n install {{ $pkgs | join " " }}
{{-       end }}
{{-     end }}
{{-     with (index $opensuse "npm_global" | default list) }}
{{-       $pkgs := . }}
{{-       range (index $ "disabled_packages" | default list) }}{{- $pkgs = without $pkgs . }}{{- end }}
{{-       if $pkgs }}
npm install -g {{ $pkgs | join " " }}
{{-       end }}
{{-     end }}
{{-     with (index $opensuse "go_install" | default list) }}
{{-       range . }}
go install {{ . }}
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}

# --- Machine-local extra packages ---
{{- with (index $ "extra_packages") }}
{{-   with (index . "opensuse" | default dict | index "zypper" | default list) }}
printf "${LCYAN}###${RESET} Installing machine-local extras (zypper)\n"
sudo zypper -n install {{ . | join " " }}
{{-   end }}
{{- end }}

{{ end -}}
