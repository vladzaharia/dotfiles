{{ if ne .chezmoi.os "darwin" }}{{ else -}}
#!/bin/sh
CYAN='\033[0;36m'
LCYAN='\033[1;36m'
YELLOW='\033[1;33m'
RESET='\033[0m'

if ! command -v brew > /dev/null 2>&1; then
    printf "${CYAN}✗${RESET} Homebrew not found — install it first: https://brew.sh\n" >&2
    exit 1
fi

# Suppress mas Spotlight indexing noise
export MAS_NO_AUTO_INDEX=1

# brew_formula: idempotent formula install — suppresses "already installed" noise,
#               upgrades if outdated, batch-installs only what is missing.
brew_formula() {
    local to_install=""
    for pkg in "$@"; do
        if brew list --formula "$pkg" > /dev/null 2>&1; then
            printf "${YELLOW}  →${RESET} ${pkg}: already installed, upgrading if outdated\n"
            brew upgrade --formula "$pkg" 2>/dev/null || true
        else
            to_install="${to_install} ${pkg}"
        fi
    done
    [ -n "$to_install" ] && brew install ${to_install} || true
}

# brew_cask: idempotent cask install that handles three cases:
#   1. Already Homebrew-managed → upgrade (no-op if current)
#   2. Exists in /Applications but unmanaged, same version → adopt
#   3. Exists in /Applications but unmanaged, wrong version → force install
brew_cask() {
    local pkg="$1"
    if brew list --cask "$pkg" > /dev/null 2>&1; then
        printf "${YELLOW}  →${RESET} ${pkg}: already managed, upgrading if outdated\n"
        brew upgrade --cask "$pkg" 2>/dev/null || true
    else
        brew install --cask --adopt "$pkg" 2>/dev/null || true
        # Re-check: adopt may exit non-zero even when it successfully registers the cask.
        # Only force-install if the cask is still unmanaged after the adopt attempt.
        if ! brew list --cask "$pkg" > /dev/null 2>&1; then
            brew install --cask --force "$pkg"
        fi
    fi
}

# mas_install: idempotent App Store install.
# Detects via filesystem (find /Applications -name "$app") rather than
# mas list / Spotlight, which is unreliable when the Spotlight index is
# read-only or out of date.
# Usage: mas_install <id> <AppName.app>
mas_install() {
    local id="$1"
    local app="$2"
    if find /Applications -maxdepth 3 -name "$app" -type d 2>/dev/null | grep -q .; then
        printf "${YELLOW}  →${RESET} ${app}: already installed\n"
    else
        mas install "$id"
    fi
}

# --- Taps ---
{{- range $group, $data := .packages }}
{{-   if or (index $data "required") (has $group $.package_groups) }}
{{-     range (index (index $data "darwin" | default dict) "tap" | default list) }}
brew tap {{ . }}
{{-     end }}
{{-   end }}
{{- end }}

# --- Core (always installed) ---
printf "${LCYAN}###${RESET} Installing core packages\n"
brew_formula {{ index (index (index $.packages "core") "darwin") "brew" | join " " }}

# --- Selected groups ---
{{- range $group := .package_groups }}
{{-   $gdata := index $.packages $group }}
{{-   if $gdata }}
printf "${LCYAN}###${RESET} Installing group: {{ $group }} — {{ index $gdata "description" }}\n"
{{-     $darwin := index $gdata "darwin" | default dict }}
{{-     with (index $darwin "pre_brew" | default list) }}
brew_formula {{ . | join " " }}
{{-     end }}
{{-     range $key, $pkgs := $darwin }}
{{-       if not (kindIs "slice" $pkgs) }}{{- continue }}{{- end }}
{{-       if hasPrefix "cask" $key }}
{{-         range (index $ "disabled_packages" | default list) }}{{- $pkgs = without $pkgs . }}{{- end }}
{{-         range $pkgs }}
brew_cask {{ . }}
{{-         end }}
{{-       else if or (eq $key "brew") (hasPrefix "brew_" $key) }}
{{-         range (index $ "disabled_packages" | default list) }}{{- $pkgs = without $pkgs . }}{{- end }}
{{-         if $pkgs }}
brew_formula {{ $pkgs | join " " }}
{{-         end }}
{{-       else if eq $key "mas" }}
{{-         range $pkgs }}
{{-           if kindIs "map" . }}
mas_install {{ index . "id" }} {{ index . "app" | quote }}
{{-           else }}
mas_install {{ . }} {{ . | quote }}
{{-           end }}
{{-         end }}
{{-       end }}
{{-     end }}
{{-     if and (eq $group "comms") $.flags.pokemon }}
{{-       $comms_pkmn := index (index $gdata "darwin" | default dict) "pkmn" | default dict }}
{{-       range (index $comms_pkmn "cask" | default list) }}
brew_cask {{ . }}
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}

# --- NPM globals and Go tools (all groups) ---
{{- range $group := .package_groups }}
{{-   $gdata := index $.packages $group }}
{{-   if $gdata }}
{{-     $gdarwin := index $gdata "darwin" | default dict }}
{{-     $npm := index $gdarwin "npm_global" | default list }}
{{-     range (index $ "disabled_packages" | default list) }}{{- $npm = without $npm . }}{{- end }}
{{-     if $npm }}
printf "${LCYAN}###${RESET} Installing NPM global packages ({{ $group }})\n"
npm install -g {{ $npm | join " " }}
{{-     end }}
{{-     with (index $gdarwin "go_install" | default list) }}
printf "${LCYAN}###${RESET} Installing Go tools ({{ $group }})\n"
{{-       range . }}
go install {{ . }}
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}

# --- Docker runtime (Apple Silicon) ---
{{- if .flags.applesilicon }}
{{-   if eq .docker.runtime "colima" }}
printf "${LCYAN}###${RESET} Installing colima (Docker runtime)\n"
brew_formula colima
{{-   end }}
{{- end }}

# --- Machine-local extra packages ---
{{- with (index $ "extra_packages") }}
{{-   with (index . "darwin" | default dict | index "brew" | default list) }}
printf "${LCYAN}###${RESET} Installing machine-local extras (brew)\n"
brew_formula {{ . | join " " }}
{{-   end }}
{{-   with (index . "darwin" | default dict | index "cask" | default list) }}
printf "${LCYAN}###${RESET} Installing machine-local extras (cask)\n"
{{-     range . }}
brew_cask {{ . }}
{{-     end }}
{{-   end }}
{{-   with (index . "darwin" | default dict | index "mas" | default list) }}
printf "${LCYAN}###${RESET} Installing machine-local extras (mas)\n"
{{-     range . }}
{{-       if kindIs "map" . }}
mas_install {{ index . "id" }} {{ index . "app" | quote }}
{{-       else }}
mas_install {{ . }} {{ . | quote }}
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}


{{ end -}}
