{{/* ============================================================ */}}
{{/* STEP 1: Auto-detect environment (must run before any prompts) */}}
{{/* ============================================================ */}}

{{- $ephemeral := (or (env "DEVPOD" | not | not) (env "GITPOD_WORKSPACE_ID" | not | not)
                      (env "CODESPACES" | not | not) (env "CODER_ENV" | not | not)) -}}
{{- $wsl       := (and (eq .chezmoi.os "linux") (.chezmoi.kernel.osrelease | lower | contains "microsoft")) -}}
{{- if or (stat "/home/kasm-default-profile") $wsl -}}{{- $ephemeral = true -}}{{- end -}}

{{- $distro     := .chezmoi.os -}}
{{- $distroLike := .chezmoi.os -}}
{{- if eq $distro "linux" -}}
{{-   $distro     = .chezmoi.osRelease.id -}}
{{-   $distroLike = (or (index .chezmoi.osRelease "idLike") .chezmoi.osRelease.id) -}}
{{- end -}}

{{- $chassisType := "desktop" -}}
{{- if $ephemeral -}}
{{-   $chassisType = "ephemeral" -}}
{{- else if stat "/home/kasm-default-profile" -}}
{{-   $chassisType = "kasm" -}}
{{- else if $wsl -}}
{{-   $chassisType = "wsl" -}}
{{- else if eq .chezmoi.hostname "beepy" -}}
{{-   $chassisType = "beepy" -}}
{{- else if eq .chezmoi.os "darwin" -}}
{{-   if contains "MacBook" (output "sysctl" "-n" "hw.model") -}}
{{-     $chassisType = "laptop" -}}
{{-   else -}}
{{-     $chassisType = "desktop" -}}
{{-   end -}}
{{- else if eq .chezmoi.os "linux" -}}
{{-   $chassisType = (output "hostnamectl" "--json=short" | mustFromJson).Chassis -}}
{{- else if eq .chezmoi.os "windows" -}}
{{-   $chassisType = (output "powershell.exe" "-noprofile" "-command" "if (Get-WmiObject -Class win32_battery -ComputerName localhost) { echo laptop } else { echo desktop }") -}}
{{- end -}}

{{/* Fastfetch color — inlined because .chezmoidata/ is not available during config template rendering */}}
{{- $fastfetchColor := "black" -}}
{{- if or (eq $distroLike "fedora") (eq .chezmoi.os "windows") (eq $distro "darwin") -}}
{{-   $fastfetchColor = "light_blue" -}}
{{- else if eq $distro "ubuntu" -}}
{{-   $fastfetchColor = "yellow" -}}
{{- else if eq $distroLike "debian" -}}
{{-   $fastfetchColor = "red" -}}
{{- else if eq $distroLike "opensuse" -}}
{{-   $fastfetchColor = "green" -}}
{{- end -}}

{{/* ============================================================ */}}
{{/* STEP 2: Prompts — SKIPPED entirely on ephemeral environments  */}}
{{/* Ephemeral gets safe, minimal defaults for non-interactive     */}}
{{/* startup (Codespaces, GitPod, Coder, DevPod workspaces)       */}}
{{/* ============================================================ */}}

{{- $identities    := list "home" -}}
{{- $pokemon       := false -}}
{{- $machineRole   := "workstation" -}}
{{- $dockerRuntime := "none" -}}
{{- $packageGroups := list -}}

{{- if not $ephemeral -}}

  {{/* Identities: multi-select — home (personal) and/or pkmn (work).
       Different first letters avoid chezmoi prefix-matching ambiguity.
       Key is "identities" (plural) so it doesn't collide with any cached "identity" string. */}}
  {{- $identities = promptMultichoiceOnce . "identities" "Select identities for this machine" (list "home" "pkmn") -}}
  {{- $pokemon    = has "pkmn" $identities -}}

  {{/* Machine role: auto-detect for known chassis types; ask only when ambiguous */}}
  {{- if or (eq $chassisType "server") (eq $chassisType "vm") -}}
  {{-   $machineRole = "server" -}}
  {{- else if and (eq .chezmoi.os "linux") (not (or (eq $chassisType "laptop") (eq $chassisType "desktop"))) -}}
  {{-   $machineRole = promptChoiceOnce . "machine_role" "What is this machine's role" (list "workstation" "server") -}}
  {{- end -}}

  {{/* Docker runtime: macOS ARM workstations only */}}
  {{- if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") -}}
  {{-   $dockerRuntime = promptChoiceOnce . "docker_runtime" "Which Docker runtime" (list "orbstack" "colima" "docker-desktop" "none") -}}
  {{- end -}}

  {{/* Package groups: offer groups appropriate for this machine */}}
  {{- $available := list "dev" "cloud" "ai" "security" -}}
  {{- if eq $machineRole "workstation" -}}
  {{-   $available = concat $available (list "apps" "gaming" "creative" "comms") -}}
  {{- end -}}
  {{- if $pokemon -}}{{- $available = append $available "pkmn" -}}{{- end -}}
  {{- $packageGroups = promptMultichoiceOnce . "package_groups" "Select package groups to install" $available -}}

{{- end -}}
{{/* On ephemeral: $packageGroups = [] → install scripts produce empty/no-op output */}}

{{/* ============================================================ */}}
{{/* STEP 3: Generate chezmoi.toml output                         */}}
{{/* ============================================================ */}}

sourceDir = {{ .chezmoi.sourceDir | quote }}

{{- if and (not $ephemeral) (ne $chassisType "beepy") }}
encryption = "age"
[age]
{{-   if $pokemon }}
    identity  = "~/.keys/pkmn.key"
    recipient = "age1chxlg7tm275f5fsw8lfpj9x76drqfgtaphu02ef7u3lurkppwqnqfwxarn"
{{-   else }}
    identity  = "~/.keys/personal.key"
    recipient = "age1hpzuwy5lhe6ke9dkj37npz9qlgcfxkk2yyl0z235xt3sgqrmqpssqsjtcm"
{{-   end }}
{{- end }}

[git]
    autoCommit = true

[data]
    chezmoi.chassis     = {{ $chassisType | quote }}
    chezmoi.distro.name = {{ $distro | quote }}
    chezmoi.distro.like = {{ $distroLike | quote }}
    docker.runtime      = {{ $dockerRuntime | quote }}
    fastfetch.color     = {{ $fastfetchColor | quote }}
    flags.applesilicon  = {{ and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") }}
    flags.ephemeral     = {{ $ephemeral }}
    flags.pokemon       = {{ $pokemon }}
    identities          = {{ $identities | toJson }}
    personal.name       = "Vlad Zaharia"
    personal.email      = {{ if $pokemon }}"v.zaharia@pokemon.com"{{ else }}"hey@vlad.gg"{{ end }}
    package_groups      = {{ $packageGroups | toJson }}
