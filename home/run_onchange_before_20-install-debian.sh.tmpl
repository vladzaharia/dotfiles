{{ if not (and (eq .chezmoi.distro.like "debian") (not (eq .chezmoi.chassis "kasm"))) }}{{ else -}}
#!/bin/sh
CYAN='\033[0;36m'
LCYAN='\033[1;36m'
RESET='\033[0m'

# --- Core (always installed) ---
printf "${LCYAN}###${RESET} Updating apt repositories\n"
sudo apt-get update

printf "${LCYAN}###${RESET} Installing core packages\n"
sudo apt-get install -y {{ .packages.core.debian.apt | join " " }}

# --- Eza (custom repo) ---
if [ ! -f /etc/apt/sources.list.d/gierens.list ]; then
    printf "${CYAN}###${RESET} Adding eza repository\n"
    sudo mkdir -p /etc/apt/keyrings
    wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
    echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list
    sudo chmod 644 /etc/apt/keyrings/gierens.gpg /etc/apt/sources.list.d/gierens.list
    sudo apt-get update
fi
sudo apt-get install -y eza

# --- Zoxide (curl install) ---
if ! command -v zoxide > /dev/null 2>&1; then
    curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# --- Fastfetch (curl install) ---
if ! command -v fastfetch > /dev/null 2>&1; then
    curl -sSL https://alessandromrc.github.io/fastfetch-installer/installer.sh | bash
fi

# --- oh-my-posh (curl install) ---
if ! command -v oh-my-posh > /dev/null 2>&1; then
    curl -s https://ohmyposh.dev/install.sh | bash -s
fi

{{- if has "dev" .package_groups }}
# --- asdf (git install) ---
if [ ! -d "$HOME/.asdf" ]; then
    printf "${LCYAN}###${RESET} Installing asdf\n"
    git clone https://github.com/asdf-vm/asdf.git "$HOME/.asdf"
else
    printf "${LCYAN}###${RESET} Updating asdf\n"
    git -C "$HOME/.asdf" pull
fi
{{- end }}

# --- Selected groups ---
{{- range $group := .package_groups }}
{{-   $gdata := index $.packages $group }}
{{-   if $gdata }}
printf "${LCYAN}###${RESET} Installing group: {{ $group }} — {{ index $gdata "description" }}\n"
{{-     $debian := index $gdata "debian" | default dict }}
{{-     with (index $debian "apt" | default list) }}
{{-       $pkgs := . }}
{{-       range (index $ "disabled_packages" | default list) }}{{- $pkgs = without $pkgs . }}{{- end }}
{{-       if $pkgs }}
sudo apt-get install -y {{ $pkgs | join " " }}
{{-       end }}
{{-     end }}
{{-     with (index $debian "npm_global" | default list) }}
{{-       $pkgs := . }}
{{-       range (index $ "disabled_packages" | default list) }}{{- $pkgs = without $pkgs . }}{{- end }}
{{-       if $pkgs }}
npm install -g {{ $pkgs | join " " }}
{{-       end }}
{{-     end }}
{{-     with (index $debian "go_install" | default list) }}
{{-       range . }}
go install {{ . }}
{{-       end }}
{{-     end }}
{{-   end }}
{{- end }}

{{- if not .flags.ephemeral }}
# --- Docker (non-ephemeral only) ---
if [ ! -f /etc/apt/sources.list.d/docker.list ]; then
    printf "${CYAN}###${RESET} Adding docker repository\n"
    curl -fsSL https://download.docker.com/linux/{{ .chezmoi.distro.name }}/gpg | sudo gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/{{ .chezmoi.distro.name }} $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
fi
sudo apt-get update
sudo apt-get install -y docker-ce docker-ce-cli containerd.io

# --- Atuin ---
if ! command -v atuin > /dev/null 2>&1; then
    printf "${LCYAN}###${RESET} Installing atuin\n"
    curl --proto '=https' --tlsv1.2 -sSf https://setup.atuin.sh | sh -s
fi
{{- end }}

# --- Machine-local extra packages ---
{{- with (index $ "extra_packages") }}
{{-   with (index . "debian" | default dict | index "apt" | default list) }}
printf "${LCYAN}###${RESET} Installing machine-local extras (apt)\n"
sudo apt-get install -y {{ . | join " " }}
{{-   end }}
{{- end }}

{{ end -}}
