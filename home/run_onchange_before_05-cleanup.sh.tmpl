#!/bin/sh
CYAN='\033[0;36m'
RESET='\033[0m'

{{ if (and (eq .chezmoi.distro.like "debian") (not (eq .chezmoi.chassis "kasm"))) -}}

# Remove Infisical repository
if [ -f /etc/apt/sources.list.d/infisical-infisical-cli.list ]; then
    printf "${CYAN}###${RESET} Removing Infisical repository\n"
    sudo rm -rf /etc/apt/sources.list.d/infisical-infisical-cli.list
fi

# Remove Infisical
if command -v infisical > /dev/null 2>&1; then
    sudo apt-get remove infisical -y
fi

# Remove Exa
if command -v exa > /dev/null 2>&1; then
    sudo apt-get remove exa -y
fi

# Remove Moon
if command -v moon > /dev/null 2>&1; then
    printf "${CYAN}###${RESET} Removing Moon\n"
    rm -rf "{{ .chezmoi.homeDir }}/.moon"
fi

# Remove deprecated tools: terraform, ugrep, nvm, volta, zrok
sudo apt-get remove -y terraform ugrep 2>/dev/null || true
rm -rf "{{ .chezmoi.homeDir }}/.nvm"
rm -rf "{{ .chezmoi.homeDir }}/.volta"
rm -rf "{{ .chezmoi.homeDir }}/.zrok"
rm -f "{{ .chezmoi.homeDir }}/.local/bin/zrok"

# Remove asdf (replaced by mise)
rm -rf "{{ .chezmoi.homeDir }}/.asdf"

{{ else if eq .chezmoi.distro.like "suse opensuse" -}}

# Remove asdf (replaced by mise)
rm -rf "{{ .chezmoi.homeDir }}/.asdf"

{{ else if eq .chezmoi.distro.name "darwin" -}}

if command -v brew > /dev/null 2>&1; then
    # Remove Infisical
    if command -v infisical > /dev/null 2>&1; then
        brew remove infisical
    fi

    # Remove Moon
    if command -v moon > /dev/null 2>&1; then
        printf "${CYAN}###${RESET} Removing Moon\n"
        rm -rf "{{ .chezmoi.homeDir }}/.moon"
    fi

    # Remove Azure CLI
    if command -v az > /dev/null 2>&1; then
        brew remove azure-cli
    fi

    # Remove Exa
    if command -v exa > /dev/null 2>&1; then
        brew remove exa
    fi

    # Remove asdf (replaced by mise)
    brew list asdf &>/dev/null && brew uninstall asdf || true
    rm -rf "{{ .chezmoi.homeDir }}/.asdf"

    # Remove deprecated tools
    brew list terraform &>/dev/null && brew uninstall terraform || true
    brew list nvm &>/dev/null && brew uninstall nvm || true
    brew list ugrep &>/dev/null && brew uninstall ugrep || true
    brew list --cask rio &>/dev/null && brew uninstall --cask rio || true
    brew list diff-so-fancy &>/dev/null && brew uninstall diff-so-fancy || true

    # Fix WaveTerm SSH parsing: comment out Include in /etc/ssh/ssh_config
    # WaveTerm's ssh_config parser (kevinburke fork) can't handle Include directives
    if grep -q "^Include /etc/ssh/ssh_config.d" /etc/ssh/ssh_config 2>/dev/null; then
        sudo sed -i '' 's|^Include /etc/ssh/ssh_config.d|#Include /etc/ssh/ssh_config.d|' /etc/ssh/ssh_config
    fi
fi

# Remove leftover tool directories and binaries
rm -rf "{{ .chezmoi.homeDir }}/.nvm"
rm -rf "{{ .chezmoi.homeDir }}/.volta"
rm -rf "{{ .chezmoi.homeDir }}/.zrok"
rm -f "{{ .chezmoi.homeDir }}/.local/bin/zrok"

{{ end -}}
